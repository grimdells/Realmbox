<Window x:Class="Realmbox.UI.AdditionalSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Additional Settings"
        Height="320"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Styles/TextStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Section: Injection -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Injection"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Auto-inject:"
                   VerticalAlignment="Center"
                   Margin="0,0,0,8"/>
        <CheckBox x:Name="ChkAutoInject"
                  Grid.Row="1" Grid.Column="1"
                  VerticalAlignment="Center"
                  Margin="0,0,0,8"
                  Content="Inject automatically after each client launch"
                  Checked="ChkAutoInject_Changed"
                  Unchecked="ChkAutoInject_Changed"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Inject delay (s):"
                   VerticalAlignment="Center"
                   Margin="0,0,0,8"/>
        <StackPanel Grid.Row="2" Grid.Column="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <TextBox x:Name="TxtAutoInjectDelay"
                     Width="60"
                     ToolTip="Seconds to wait after the client launches before injecting"/>
            <TextBlock Text="seconds"
                       VerticalAlignment="Center"
                       Foreground="Gray"
                       Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Separator -->
        <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,4,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Save"
                    Style="{StaticResource ActionButton}"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="BtnSave_Click"/>
            <Button Content="Close"
                    Style="{StaticResource DangerButton}"
                    Width="80"
                    Click="BtnClose_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
