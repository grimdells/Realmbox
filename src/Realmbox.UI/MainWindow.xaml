<Window x:Class="Realmbox.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Realmbox.UI.Controls"
        xmlns:pages="clr-namespace:Realmbox.UI"
        Title="Realmbox"
        Height="600"
        Width="1100"
        MinHeight="400"
        MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/Styles/CommonStyles.xaml"/>
                <ResourceDictionary Source="/Styles/TextStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Nav button style -->
            <Style x:Key="NavButton" TargetType="RadioButton">
                <Setter Property="Height"             Value="42"/>
                <Setter Property="Padding"            Value="16,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment"   Value="Center"/>
                <Setter Property="FontSize"           Value="13"/>
                <Setter Property="FontFamily"         Value="Segoe UI"/>
                <Setter Property="Foreground"         Value="#555"/>
                <Setter Property="Background"         Value="Transparent"/>
                <Setter Property="BorderThickness"    Value="0"/>
                <Setter Property="Cursor"             Value="Hand"/>
                <Setter Property="GroupName"          Value="Nav"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="3,0,0,0"
                                    BorderBrush="Transparent">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F0F2FF"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#EEF0FF"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#6366F1"/>
                                    <Setter Property="Foreground" Value="#4F46E5"/>
                                    <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>

        <DockPanel>

            <!-- ── Menu Bar ──────────────────────────────────────────────── -->
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="Tools">
                    <MenuItem Header="Inject"            Click="MenuOpenClient_Click"/>
                    <MenuItem Header="Close All Clients" Click="MenuCloseAllClients_Click"/>
                </MenuItem>
                <MenuItem Header="Settings">
                    <MenuItem Header="Injector Path"         Click="MenuClientPath_Click"/>
                    <MenuItem Header="Exalt Path"          Click="MenuExaltPath_Click"/>
                    <MenuItem Header="Device Token"        Click="MenuDeviceToken_Click"/>
                    <Separator/>
                    <MenuItem Header="Additional Settings" Click="MenuAdditionalSettings_Click"/>
                </MenuItem>
            </Menu>

            <!-- ── About strip ────────────────────────────────────────────── -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,6">
                <TextBlock Text="Reimagined by Grimdells 🐈❤️"
                           Style="{StaticResource AboutTextStyle}"/>
                <TextBlock Text="|" Style="{StaticResource AboutTextStyle}"/>
                <TextBlock Style="{StaticResource AboutTextStyle}">
                    <Hyperlink NavigateUri="https://github.com/grimdells/Realmbox"
                               RequestNavigate="Hyperlink_RequestNavigate">Github</Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- ── Body: sidebar + content ───────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="#FAFBFF"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- App title -->
                        <Border DockPanel.Dock="Top"
                                Padding="12,10,16,10"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="/Resources/icon.ico"
                                       Width="22" Height="22"
                                       Margin="0,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="Realmbox"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="15"
                                           Foreground="#1E293B"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Nav items -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                            <RadioButton x:Name="NavAccounts"
                                         Content="🗂  Accounts"
                                         Style="{StaticResource NavButton}"
                                         IsChecked="True"
                                         Click="Nav_Click"/>
                        </StackPanel>

                    </DockPanel>
                </Border>

                <!-- Divider -->
                <GridSplitter Grid.Column="1"
                              Width="1"
                              Background="#E2E8F0"
                              ResizeBehavior="PreviousAndNext"
                              IsEnabled="False"/>

                <!-- ── PAGE: Accounts ─────────────────────────────────────── -->
                <DockPanel x:Name="PageAccounts" Grid.Column="2" Visibility="Visible">

                    <!-- Launch Group bar -->
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            CornerRadius="3"
                            Margin="10,0,10,4"
                            Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Launch Group:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbGroups"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      ToolTip="Select a group to launch all accounts in it"/>
                            <TextBlock Text="Delay (s):"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Margin="12,0,8,0"/>
                            <TextBox x:Name="TxtGroupDelay"
                                     Grid.Column="3"
                                     VerticalAlignment="Center"
                                     Text="{Binding GroupLaunchDelay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button x:Name="BtnLaunchGroup"
                                    Grid.Column="4"
                                    Content="Launch"
                                    Click="BtnLaunchGroup_Click"
                                    Style="{StaticResource ActionButton}"
                                    Margin="12,0,0,0"
                                    Padding="10,4"/>
                            <TextBlock x:Name="TxtGroupLaunchStatus"
                                       Grid.Column="6"
                                       VerticalAlignment="Center"
                                       Foreground="Gray"
                                       Margin="12,0,0,0"
                                       Text=""/>
                        </Grid>
                    </Border>

                    <!-- Accounts GroupBox -->
                    <GroupBox Header="Accounts" Margin="10,4,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button Content="Add Account"
                                    Grid.Row="0"
                                    Click="BtnAddAccount_Click"
                                    Width="100"
                                    HorizontalAlignment="Right"
                                    Margin="5"/>
                            <DataGrid Name="AccountsGrid"
                                      Grid.Row="1"
                                      ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      GridLinesVisibility="All"
                                      BorderThickness="1"
                                      Margin="5"
                                      AllowDrop="True"
                                      PreviewMouseLeftButtonDown="AccountsGrid_PreviewMouseLeftButtonDown"
                                      MouseMove="AccountsGrid_MouseMove"
                                      Drop="AccountsGrid_Drop">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="5"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="5"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Proxy" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center" Padding="5">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="None"/>
                                                            <Setter Property="Foreground" Value="Gray"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasProxy}" Value="True">
                                                                    <Setter Property="Text" Value="{Binding ProxyDisplay}"/>
                                                                    <Setter Property="Foreground" Value="Green"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Actions" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Launch" Click="BtnOpenSelectedItem_Click" Style="{StaticResource ActionButton}" Margin="2"/>
                                                    <Button Content="Edit"   Click="BtnEditAccount_Click"     Style="{StaticResource ActionButton}" Margin="2"/>
                                                    <Button Content="Delete" Click="BtnDelete_Click"          Style="{StaticResource DangerButton}" Margin="2"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>

                </DockPanel>

            </Grid><!-- body columns grid -->

        </DockPanel>

        <!-- Snackbar floats over everything -->
        <controls:Snackbar x:Name="SnackbarElement"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"
                           Panel.ZIndex="1000"/>

    </Grid>
</Window>
